# ── Server ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── PostgreSQL ────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=akshara_school
DB_USER=akshara_user
DB_PASSWORD=your_strong_password_here
DB_POOL_MAX=10
DB_POOL_IDLE=30000
DB_POOL_ACQUIRE=60000

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=replace_with_a_random_64_char_secret
JWT_EXPIRES_IN=8h

# ── SMS Gateway (MSG91) ───────────────────────────────────
SMS_PROVIDER=msg91           # msg91 | twilio | valuefirst
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_SENDER_ID=AKSHRA
MSG91_TEMPLATE_RECEIPT=your_template_id_receipt
MSG91_TEMPLATE_REMINDER=your_template_id_reminder

# ── File Uploads ─────────────────────────────────────────
UPLOAD_MAX_SIZE_MB=5
UPLOAD_DIR=./uploads

# ── Frontend CORS origin ─────────────────────────────────
CLIENT_ORIGIN=http://localhost:5173
